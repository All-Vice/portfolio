---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Github, ExternalLink, Zap, FolderOpen } from 'lucide-astro';

const projects = [
  {
    title: 'Omni-Server Frame',
    description: 'AI-powered GitHub development platform with Kilo integration',
    tags: ['Node.js', 'TypeScript', 'WebSocket', 'SQLite'],
    link: 'https://github.com/All-Vice/Omni-Server-Frame',
    featured: true,
  },
  {
    title: 'Portfolio Website',
    description: 'Modern bento grid portfolio with dark mode',
    tags: ['Astro', 'Tailwind', 'TypeScript'],
    link: '#',
    featured: true,
  },
  {
    title: 'E-commerce Platform',
    description: 'Full-featured online store with payment integration',
    tags: ['React', 'Node.js', 'PostgreSQL', 'Stripe'],
    link: '#',
    featured: false,
  },
  {
    title: 'Dashboard UI',
    description: 'Analytics dashboard with real-time data visualization',
    tags: ['React', 'D3.js', 'TypeScript'],
    link: '#',
    featured: false,
  },
  {
    title: 'Blog Platform',
    description: 'MDX-powered technical blog with syntax highlighting',
    tags: ['Astro', 'MDX', 'Tailwind'],
    link: '#',
    featured: false,
  },
  {
    title: 'Design System',
    description: 'Component library with documentation site',
    tags: ['React', 'Storybook', 'Tailwind'],
    link: '#',
    featured: false,
  },
];
---

<BaseLayout title="Portfolio | All-Vice">
  <Navigation />
  
  <main class="pt-24">
    <section class="section-py">
      <div class="container-main">
        <h1 class="hero-title mb-4 animate-on-scroll">
          Portfolio
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mb-12 animate-on-scroll stagger-2" style="line-height: 1.7;">
          A collection of projects showcasing my work in web design and development.
        </p>

        <!-- Featured Projects -->
        <h2 class="text-2xl font-bold mb-6 animate-on-scroll">Featured Projects</h2>
        <div class="grid md:grid-cols-2 gap-6 mb-12">
          {projects.filter(p => p.featured).map((project, index) => (
            <a 
              href={project.link} 
              class="bento-card group block animate-on-scroll" 
              style={`animation-delay: ${index * 0.1}s`}
              target="_blank" 
              rel="noopener"
            >
              <div class="aspect-video rounded-2xl bg-gradient-to-br from-accent/20 to-accent-tertiary/20 mb-4 flex items-center justify-center relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-background/30 to-transparent"></div>
                <Zap size={48} class="text-accent/50 group-hover:scale-110 transition-transform" />
              </div>
              <h3 class="text-xl font-bold mb-2 group-hover:text-accent transition-colors">
                {project.title}
              </h3>
              <p class="text-text-secondary mb-4" style="line-height: 1.6;">{project.description}</p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>

        <!-- Other Projects -->
        <h2 class="text-2xl font-bold mb-6 animate-on-scroll">Other Projects</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {projects.filter(p => !p.featured).map((project, index) => (
            <a 
              href={project.link} 
              class="bento-card group block animate-on-scroll" 
              style={`animation-delay: ${index * 0.1}s`}
              target="_blank" 
              rel="noopener"
            >
              <div class="flex items-center gap-2 mb-3">
                <FolderOpen size={18} class="text-accent" />
                <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">
                  {project.title}
                </h3>
              </div>
              <p class="text-sm text-text-secondary mb-4" style="line-height: 1.6;">{project.description}</p>
              <div class="flex flex-wrap gap-2">
                {project.tags.map(tag => (
                  <span class="tag text-xs">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- GitHub Stats -->
    <section class="section-py-sm pb-24">
      <div class="container-main">
        <div class="bento-card">
          <div class="flex items-center gap-3 mb-6">
            <Github size={24} class="text-accent" />
            <h2 class="text-2xl font-bold">GitHub Activity</h2>
          </div>
          <div class="flex gap-4 items-center overflow-hidden rounded-xl">
            <img 
              src="https://github-readme-stats.vercel.app/api?username=All-Vice&show_icons=true&theme=transparent&hide_border=true&bg_color=0a0a0f" 
              alt="GitHub Stats"
              class="w-full max-w-md"
            />
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
