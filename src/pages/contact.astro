---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { Mail, Github, Twitter, Linkedin, Send, Clock } from 'lucide-astro';
---

<BaseLayout title="Contact | All-Vice">
  <Navigation />
  
  <main class="pt-24">
    <section class="section-py">
      <div class="container-main">
        <h1 class="hero-title mb-4 animate-on-scroll">
          Get In Touch
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mb-12 animate-on-scroll stagger-2" style="line-height: 1.7;">
          Have a project in mind? Let's discuss how I can help bring your vision to life.
        </p>

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Contact Form -->
          <div class="animate-on-scroll stagger-3">
            <form class="space-y-6">
              <div>
                <label for="name" class="block text-sm font-medium mb-2">Name</label>
                <input 
                  type="text" 
                  id="name" 
                  name="name"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-surface focus:border-accent focus:outline-none transition-colors"
                  placeholder="Your name"
                  required
                />
              </div>
              
              <div>
                <label for="email" class="block text-sm font-medium mb-2">Email</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-surface focus:border-accent focus:outline-none transition-colors"
                  placeholder="your@email.com"
                  required
                />
              </div>
              
              <div>
                <label for="subject" class="block text-sm font-medium mb-2">Subject</label>
                <select 
                  id="subject" 
                  name="subject"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-surface focus:border-accent focus:outline-none transition-colors"
                >
                  <option value="">Select a topic</option>
                  <option value="project">New Project</option>
                  <option value="question">Question</option>
                  <option value="collaboration">Collaboration</option>
                  <option value="other">Other</option>
                </select>
              </div>
              
              <div>
                <label for="message" class="block text-sm font-medium mb-2">Message</label>
                <textarea 
                  id="message" 
                  name="message"
                  rows="5"
                  class="w-full px-4 py-3 rounded-xl border border-border bg-surface focus:border-accent focus:outline-none transition-colors resize-none"
                  placeholder="Tell me about your project..."
                  required
                ></textarea>
              </div>
              
              <button type="submit" class="btn-primary w-full group">
                <Send size={18} />
                <span>Send Message</span>
              </button>
            </form>
          </div>

          <!-- Contact Info -->
          <div class="space-y-6">
            <!-- Email -->
            <div class="bento-card animate-on-scroll stagger-4">
              <div class="flex items-start gap-4">
                <div class="icon-glass">
                  <Mail size={20} />
                </div>
                <div>
                  <h3 class="font-semibold mb-1">Email</h3>
                  <a href="mailto:hello@all-vice.dev" class="text-accent hover:underline">
                    hello@all-vice.dev
                  </a>
                  <p class="text-sm text-text-muted mt-1">I'll respond within 24-48 hours</p>
                </div>
              </div>
            </div>

            <!-- Social -->
            <div class="bento-card animate-on-scroll stagger-5">
              <h3 class="font-semibold mb-4">Connect</h3>
              <div class="flex gap-3">
                <a 
                  href="https://github.com/All-Vice" 
                  target="_blank"
                  rel="noopener noreferrer"
                  class="icon-glass hover:text-accent"
                  aria-label="GitHub"
                >
                  <Github size={20} />
                </a>
                <a 
                  href="#" 
                  class="icon-glass hover:text-accent"
                  aria-label="Twitter"
                >
                  <Twitter size={20} />
                </a>
                <a 
                  href="#" 
                  class="icon-glass hover:text-accent"
                  aria-label="LinkedIn"
                >
                  <Linkedin size={20} />
                </a>
              </div>
            </div>

            <!-- Availability -->
            <div class="bento-card animate-on-scroll stagger-6">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-3 h-3 rounded-full bg-success animate-pulse"></div>
                <h3 class="font-semibold">Available for Projects</h3>
              </div>
              <p class="text-text-secondary text-sm" style="line-height: 1.6;">
                I'm currently accepting new projects. Let's discuss your ideas!
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
