---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { FileText, Calendar, ArrowRight, Mail, Send } from 'lucide-astro';

const posts = [
  {
    title: 'The Complete Guide to Bento Grid Layouts in 2026',
    excerpt: 'Learn how to create stunning bento grid layouts using modern CSS Grid techniques.',
    date: '2026-03-11',
    category: 'Design',
    slug: 'bento-grid-guide',
  },
  {
    title: 'Building a Design System from Scratch',
    excerpt: 'A comprehensive guide to creating scalable design systems for your projects.',
    date: '2026-03-01',
    category: 'Design Systems',
    slug: 'design-system-guide',
  },
  {
    title: 'Modern Color Theory for Developers',
    excerpt: 'Understanding color theory and creating beautiful palettes for web projects.',
    date: '2026-02-15',
    category: 'Color',
    slug: 'color-theory',
  },
];
---

<BaseLayout title="Blog | All-Vice">
  <Navigation />
  
  <main class="pt-24">
    <section class="section-py">
      <div class="container-main">
        <h1 class="hero-title mb-4 animate-on-scroll">
          Blog
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mb-12 animate-on-scroll stagger-2" style="line-height: 1.7;">
          Thoughts on web design, development, and creating great user experiences.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post, index) => (
            <article class="bento-card group cursor-pointer animate-on-scroll" style={`animation-delay: ${index * 0.1}s`}>
              <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-accent/10 text-accent mb-3">
                {post.category}
              </span>
              <h2 class="text-xl font-bold mb-2 group-hover:text-accent transition-colors">
                {post.title}
              </h2>
              <p class="text-text-secondary text-sm mb-4" style="line-height: 1.6;">{post.excerpt}</p>
              <div class="flex items-center justify-between">
                <span class="text-sm text-text-muted flex items-center gap-1">
                  <Calendar size={14} />
                  {post.date}
                </span>
                <span class="text-accent text-sm group-hover:translate-x-1 transition-transform flex items-center gap-1">
                  Read <ArrowRight size={14} />
                </span>
              </div>
            </article>
          ))}
        </div>

        <!-- Coming Soon -->
        <div class="mt-12 bento-card text-center py-12 animate-on-scroll">
          <FileText size={48} class="mx-auto mb-4 text-text-muted" />
          <h2 class="text-xl font-bold mb-2">More Articles Coming Soon</h2>
          <p class="text-text-secondary" style="line-height: 1.6;">
            I'm working on in-depth tutorials and guides about web design. Check back soon!
          </p>
        </div>
      </div>
    </section>

    <!-- Newsletter -->
    <section class="section-py-sm pb-24">
      <div class="container-main">
        <div class="bento-card text-center" style="background: linear-gradient(135deg, rgba(139,92,246,0.1) 0%, rgba(244,114,182,0.05) 100%); border-color: rgba(139,92,246,0.2);">
          <div class="flex items-center justify-center gap-2 mb-4">
            <Mail size={24} class="text-accent" />
            <h2 class="text-2xl font-bold">Stay Updated</h2>
          </div>
          <p class="text-text-secondary mb-8 max-w-md mx-auto" style="line-height: 1.7;">
            Subscribe to get notified when I publish new articles about web design and development.
          </p>
          <form class="flex gap-2 max-w-md mx-auto flex-col sm:flex-row">
            <input 
              type="email" 
              placeholder="your@email.com" 
              class="flex-1 px-4 py-3 rounded-xl border border-border bg-surface focus:border-accent focus:outline-none transition-colors"
            />
            <button type="submit" class="btn-primary whitespace-nowrap">
              <Send size={18} />
              Subscribe
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
