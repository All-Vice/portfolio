---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { label: 'Years Experience', value: '5+' },
  { label: 'Projects Completed', value: '50+' },
  { label: 'Happy Clients', value: '30+' },
];

const services = [
  { title: 'Web Design', description: 'Beautiful, functional designs that convert' },
  { title: 'UI/UX', description: 'User-centered experiences that delight' },
  { title: 'Development', description: 'Clean code, fast performance' },
];

const skills = ['Astro', 'React', 'TypeScript', 'Tailwind', 'Figma', 'Node.js', 'GitHub', 'CSS Grid'];
---

<BaseLayout title="All-Vice | Web Designer">
  <Navigation />
  
  <main class="pt-24">
    <!-- Hero Section -->
    <section class="container py-20">
      <div class="max-w-4xl">
        <p class="text-accent font-medium mb-4">Hello, I'm</p>
        <h1 class="text-5xl md:text-hero font-heading font-bold mb-6">
          Building websites<br />
          <span class="gradient-text">that matter.</span>
        </h1>
        <p class="text-xl text-text-secondary max-w-2xl mb-8">
          Web designer specializing in modern design systems, 
          bento grids, and creating memorable user experiences.
        </p>
        <div class="flex gap-4">
          <a href="/portfolio" class="btn btn-primary">
            View My Work
          </a>
          <a href="/contact" class="btn btn-outline">
            Get In Touch
          </a>
        </div>
      </div>
    </section>

    <!-- Bento Grid -->
    <section class="container pb-20">
      <div class="bento-grid">
        <!-- Bio Card -->
        <div class="bento-lg card">
          <h2 class="text-2xl font-heading font-bold mb-4">About Me</h2>
          <p class="text-text-secondary mb-4">
            I'm a passionate web designer who loves creating beautiful, 
            functional websites. I specialize in modern design systems 
            and clean code.
          </p>
          <p class="text-text-secondary">
            When I'm not designing, you'll find me exploring new web 
            technologies and contributing to open source projects.
          </p>
        </div>

        <!-- Stats Card -->
        <div class="bento-md card">
          <h3 class="text-lg font-heading font-semibold mb-6">Quick Stats</h3>
          <div class="grid grid-cols-3 gap-4">
            {stats.map(stat => (
              <div class="text-center">
                <div class="text-3xl font-bold gradient-text">{stat.value}</div>
                <div class="text-sm text-text-secondary">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Services Card -->
        <div class="bento-md card">
          <h3 class="text-lg font-heading font-semibold mb-4">Services</h3>
          <div class="space-y-4">
            {services.map(service => (
              <div class="p-4 rounded-lg bg-surface-alt">
                <h4 class="font-semibold mb-1">{service.title}</h4>
                <p class="text-sm text-text-secondary">{service.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Skills Card -->
        <div class="bento-sm card">
          <h3 class="text-lg font-heading font-semibold mb-4">Tech Stack</h3>
          <div class="flex flex-wrap gap-2">
            {skills.map(skill => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </div>

        <!-- Featured Project Card -->
        <div class="bento-md card group cursor-pointer">
          <h3 class="text-lg font-heading font-semibold mb-4">Featured Project</h3>
          <div class="aspect-video rounded-lg bg-gradient-to-br from-accent/20 to-accent-tertiary/20 mb-4 flex items-center justify-center">
            <span class="text-4xl">🚀</span>
          </div>
          <h4 class="font-semibold mb-2 group-hover:text-accent transition-colors">
            Omni-Server Frame
          </h4>
          <p class="text-sm text-text-secondary">
            AI-powered GitHub development platform
          </p>
        </div>

        <!-- Latest Blog Card -->
        <div class="bento-sm card group cursor-pointer">
          <h3 class="text-lg font-heading font-semibold mb-4">Latest Post</h3>
          <div class="p-4 rounded-lg bg-surface-alt mb-4">
            <span class="text-2xl">📝</span>
          </div>
          <h4 class="font-semibold mb-2 group-hover:text-accent transition-colors text-sm">
            The Complete Guide to Bento Grids
          </h4>
          <p class="text-xs text-text-secondary">Coming soon...</p>
        </div>

        <!-- CTA Card -->
        <div class="bento-md card bg-gradient-to-br from-accent/10 to-accent-tertiary/10 border-accent/20">
          <h3 class="text-lg font-heading font-semibold mb-4">Let's Work Together</h3>
          <p class="text-text-secondary mb-6">
            Have a project in mind? I'd love to hear about it.
          </p>
          <a href="/contact" class="btn btn-primary">
            Start a Project
          </a>
        </div>

        <!-- Social/Connect Card -->
        <div class="bento-sm card">
          <h3 class="text-lg font-heading font-semibold mb-4">Connect</h3>
          <div class="space-y-3">
            <a href="https://github.com/All-Vice" class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-alt transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              <span>GitHub</span>
            </a>
            <a href="#" class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-alt transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span>LinkedIn</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
