---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { 
  Rocket, 
  Code, 
  Palette, 
  Layers, 
  Github, 
  Figma, 
  Grid3X3, 
  Server,
  TrendingUp,
  Users,
  Briefcase,
  ArrowRight,
  Zap,
  FileText,
  MessageCircle,
  Linkedin,
  Twitter,
  Mail
} from 'lucide-astro';

const skills = [
  { name: 'Astro', icon: Rocket },
  { name: 'React', icon: Code },
  { name: 'TypeScript', icon: Code },
  { name: 'Tailwind', icon: Layers },
  { name: 'Node.js', icon: Server },
  { name: 'GitHub', icon: Github },
  { name: 'Figma', icon: Figma },
  { name: 'CSS Grid', icon: Grid3X3 },
];

const services = [
  { title: 'Web Design', description: 'Beautiful, conversion-focused designs', icon: Palette },
  { title: 'Frontend Dev', description: 'Clean, performant code', icon: Code },
  { title: 'UI/UX', description: 'User-centered experiences', icon: Layers },
];

const socialLinks = [
  { href: 'https://github.com/All-Vice', label: 'GitHub', icon: Github },
  { href: '#', label: 'Twitter', icon: Twitter },
  { href: '#', label: 'LinkedIn', icon: Linkedin },
];
---

<BaseLayout title="All-Vice | Web Designer & Developer">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="section-py relative overflow-hidden">
      <!-- Animated gradient orbs -->
      <div class="absolute top-20 left-1/4 w-96 h-96 bg-accent/20 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-20 right-1/4 w-80 h-80 bg-accent-secondary/15 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
      
      <div class="container-main">
        <div class="max-w-4xl">
          <div class="animate-on-scroll">
            <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-accent/10 border border-accent/20 text-accent mb-6">
              <Zap size={14} class="text-accent-secondary" />
              Available for projects
            </span>
          </div>
          
          <h1 class="hero-title mb-6 animate-on-scroll stagger-1">
            Building websites<br />
            <span class="text-gradient-glow">that matter.</span>
          </h1>
          
          <p class="text-xl text-text-secondary max-w-2xl mb-10 animate-on-scroll stagger-2" style="line-height: 1.7;">
            Web designer & developer crafting beautiful, functional websites. 
            Specialized in modern design systems, bento grids, and creating memorable user experiences.
          </p>
          
          <div class="flex flex-wrap gap-4 animate-on-scroll stagger-3">
            <a href="/portfolio" class="btn-primary group">
              <span>View My Work</span>
              <ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
            </a>
            <a href="/contact" class="btn-secondary">
              <MessageCircle size={18} />
              <span>Get In Touch</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bento Grid -->
    <section class="container-main pb-24">
      <div class="bento-grid">
        
        <!-- Bio Card -->
        <div class="bento-lg bento-card animate-on-scroll stagger-2">
          <div class="flex items-start justify-between mb-4">
            <h2 class="text-2xl font-bold">About Me</h2>
            <div class="icon-glass">
              <Users size={20} />
            </div>
          </div>
          <p class="text-text-secondary mb-4" style="line-height: 1.7;">
            I'm a passionate web designer & developer who loves creating beautiful, 
            functional websites. I specialize in modern design systems and clean code.
          </p>
          <p class="text-text-secondary" style="line-height: 1.7;">
            When I'm not designing, you'll find me exploring new web technologies 
            and contributing to open source projects.
          </p>
        </div>

        <!-- Stats Card -->
        <div class="bento-md bento-card animate-on-scroll stagger-3">
          <div class="flex items-center gap-3 mb-6">
            <div class="icon-glass">
              <TrendingUp size={20} />
            </div>
            <h3 class="text-lg font-semibold">Quick Stats</h3>
          </div>
          <div class="grid grid-cols-3 gap-4">
            <div class="text-center">
              <div class="stat-number">5+</div>
              <div class="text-sm text-text-muted mt-1">Years</div>
            </div>
            <div class="text-center">
              <div class="stat-number">50+</div>
              <div class="text-sm text-text-muted mt-1">Projects</div>
            </div>
            <div class="text-center">
              <div class="stat-number">30+</div>
              <div class="text-sm text-text-muted mt-1">Clients</div>
            </div>
          </div>
        </div>

        <!-- Services Card -->
        <div class="bento-md bento-card animate-on-scroll stagger-4">
          <div class="flex items-center gap-3 mb-6">
            <div class="icon-glass">
              <Briefcase size={20} />
            </div>
            <h3 class="text-lg font-semibold">Services</h3>
          </div>
          <div class="space-y-3">
            {services.map(service => (
              <div class="p-4 rounded-2xl bg-white/5 border border-border/50 hover:border-accent/30 transition-colors">
                <div class="flex items-center gap-3">
                  <service.icon size={18} class="text-accent" />
                  <div>
                    <h4 class="font-semibold text-sm">{service.title}</h4>
                    <p class="text-xs text-text-muted">{service.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Skills Card -->
        <div class="bento-sm bento-card animate-on-scroll stagger-4">
          <div class="flex items-center gap-3 mb-4">
            <div class="icon-glass">
              <Layers size={20} />
            </div>
            <h3 class="text-lg font-semibold">Tech Stack</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {skills.map(skill => (
              <span class="tag">
                <skill.icon size={14} />
                {skill.name}
              </span>
            ))}
          </div>
        </div>

        <!-- Featured Project -->
        <div class="bento-md bento-card group animate-on-scroll stagger-5" style="cursor: pointer;">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">Featured Project</h3>
            <ArrowRight size={20} class="transition-transform group-hover:translate-x-1 text-text-muted" />
          </div>
          <div class="aspect-video rounded-2xl mb-4 flex items-center justify-center relative overflow-hidden bg-gradient-to-br from-accent/20 to-accent-tertiary/20 group-hover:from-accent/30 group-hover:to-accent-tertiary/30 transition-all">
            <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-transparent"></div>
            <Zap size={48} class="text-accent relative z-10" />
          </div>
          <h4 class="font-semibold mb-1 group-hover:text-accent transition-colors">
            Omni-Server Frame
          </h4>
          <p class="text-sm text-text-muted">
            AI-powered GitHub development platform
          </p>
        </div>

        <!-- Latest Post -->
        <div class="bento-sm bento-card group animate-on-scroll stagger-5" style="cursor: pointer;">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold">Latest Post</h3>
            <ArrowRight size={20} class="transition-transform group-hover:translate-x-1 text-text-muted" />
          </div>
          <div class="aspect-square rounded-2xl mb-4 flex items-center justify-center bg-gradient-to-br from-accent-secondary/10 to-accent/10 group-hover:from-accent-secondary/20 group-hover:to-accent/20 transition-all">
            <FileText size={32} class="text-accent-secondary" />
          </div>
          <h4 class="font-semibold mb-1 group-hover:text-accent transition-colors text-sm">
            The Complete Guide to Bento Grids
          </h4>
          <p class="text-xs text-text-muted">Coming soon...</p>
        </div>

        <!-- CTA Card -->
        <div class="bento-md bento-card animate-on-scroll stagger-6" style="background: linear-gradient(135deg, rgba(139,92,246,0.1) 0%, rgba(244,114,182,0.05) 100%); border-color: rgba(139,92,246,0.2);">
          <div class="flex items-center gap-3 mb-4">
            <h3 class="text-lg font-semibold">Let's Work Together</h3>
          </div>
          <p class="text-text-secondary mb-6">
            Have a project in mind? I'd love to hear about it.
          </p>
          <a href="/contact" class="btn-primary group">
            <span>Start a Project</span>
            <ArrowRight size={18} class="transition-transform group-hover:translate-x-1" />
          </a>
        </div>

        <!-- Social Connect -->
        <div class="bento-sm bento-card animate-on-scroll stagger-6">
          <div class="flex items-center gap-3 mb-4">
            <div class="icon-glass">
              <MessageCircle size={20} />
            </div>
            <h3 class="text-lg font-semibold">Connect</h3>
          </div>
          <div class="space-y-2">
            {socialLinks.map(link => (
              <a 
                href={link.href}
                class="flex items-center gap-3 p-3 rounded-xl transition-all hover:bg-white/5 group"
              >
                <link.icon size={18} />
                <span class="text-sm font-medium">{link.label}</span>
                <ArrowRight size={16} class="ml-auto opacity-0 group-hover:opacity-100 transition-opacity text-text-muted" />
              </a>
            ))}
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
