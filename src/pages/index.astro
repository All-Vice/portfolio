---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { 
  Rocket, 
  Code, 
  Palette, 
  Layers, 
  Github, 
  Figma, 
  Grid3X3, 
  Server,
  TrendingUp,
  Users,
  Briefcase,
  ArrowRight,
  Zap,
  FileText,
  MessageCircle,
  Linkedin,
  Twitter,
  Mail,
  Eye,
  Sparkles,
  Heart,
  ExternalLink
} from 'lucide-astro';

const skills = [
  { name: 'Astro', icon: Rocket, color: 'accent' },
  { name: 'React', icon: Code, color: 'cyan' },
  { name: 'TypeScript', icon: Code, color: 'cyan' },
  { name: 'Tailwind', icon: Layers, color: 'accent' },
  { name: 'Node.js', icon: Server, color: 'pink' },
  { name: 'GitHub', icon: Github, color: 'accent' },
  { name: 'Figma', icon: Figma, color: 'pink' },
  { name: 'CSS Grid', icon: Grid3X3, color: 'cyan' },
];

const services = [
  { title: 'Web Design', description: 'Beautiful, conversion-focused designs that capture your brand essence', icon: Palette, color: 'accent' },
  { title: 'Frontend Dev', description: 'Clean, performant code using modern technologies', icon: Code, color: 'cyan' },
  { title: 'UI/UX', description: 'User-centered experiences that delight', icon: Layers, color: 'pink' },
];

const socialLinks = [
  { href: 'https://github.com/All-Vice', label: 'GitHub', icon: Github },
  { href: '#', label: 'Twitter', icon: Twitter },
  { href: '#', label: 'LinkedIn', icon: Linkedin },
];
---

<BaseLayout title="All-Vice | Web Designer & Developer">
  <Navigation />
  
  <main>
    <!-- Hero Section -->
    <section class="section-py relative overflow-hidden bg-[#0a0a0f]">
      
      <div class="container-main relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <div class="animate-on-scroll">
            <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium bg-accent/10 border border-accent/20 text-accent mb-8">
              <Sparkles size={16} class="text-cyan" />
              Available for projects
            </span>
          </div>
          
          <h1 class="hero-title mb-8 animate-on-scroll stagger-1" style="font-size: clamp(3rem, 8vw, 5.5rem);">
            Building websites<br />
            <span class="text-gradient-glow">that matter.</span>
          </h1>
          
          <p class="text-xl text-text-secondary max-w-2xl mx-auto mb-12 animate-on-scroll stagger-2" style="font-size: 1.25rem; line-height: 1.8;">
            Web designer & developer crafting beautiful, functional websites. 
            Specialized in modern design systems, bento grids, and creating memorable user experiences.
          </p>
          
          <div class="flex flex-wrap justify-center gap-4 animate-on-scroll stagger-3">
            <a href="/portfolio" class="btn-primary group text-base px-8 py-4">
              <span>View My Work</span>
              <ArrowRight size={20} class="transition-transform group-hover:translate-x-1" />
            </a>
            <a href="/contact" class="btn-secondary text-base px-8 py-4">
              <MessageCircle size={20} />
              <span>Get In Touch</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Bento Grid -->
    <section class="container-main pb-32">
      <div class="bento-grid">
        
        <!-- Bio Card - Large prominent card -->
        <div class="bento-lg bento-card bento-card-accent animate-on-scroll stagger-2">
          <div class="bento-card-header">
            <div class="bento-card-icon">
              <Users size={24} class="text-accent" />
            </div>
            <span class="text-xs font-medium text-text-muted uppercase tracking-widest">About</span>
          </div>
          <h2 class="bento-card-title text-2xl">About Me</h2>
          <div class="bento-card-content">
            <p class="mb-4">
              I'm a passionate web designer & developer who loves creating beautiful, 
              functional websites. I specialize in modern design systems and clean code.
            </p>
            <p>
              When I'm not designing, you'll find me exploring new web technologies 
              and contributing to open source projects.
            </p>
          </div>
        </div>

        <!-- Stats Card -->
        <div class="bento-md bento-card bento-card-cyan animate-on-scroll stagger-3">
          <div class="bento-card-header">
            <div class="bento-card-icon" style="background: linear-gradient(135deg, rgba(34,211,238,0.2) 0%, rgba(34,211,238,0.1) 100%); border-color: rgba(34,211,238,0.2);">
              <TrendingUp size={24} class="text-cyan" />
            </div>
            <span class="text-xs font-medium text-text-muted uppercase tracking-widest">Stats</span>
          </div>
          <div class="grid grid-cols-3 gap-4 py-4">
            <div class="bento-stat">
              <div class="bento-stat-value">5+</div>
              <div class="bento-stat-label">Years</div>
            </div>
            <div class="bento-stat">
              <div class="bento-stat-value">50+</div>
              <div class="bento-stat-label">Projects</div>
            </div>
            <div class="bento-stat">
              <div class="bento-stat-value">30+</div>
              <div class="bento-stat-label">Clients</div>
            </div>
          </div>
        </div>

        <!-- Services Card -->
        <div class="bento-md bento-card bento-card-pink animate-on-scroll stagger-4">
          <div class="bento-card-header">
            <div class="bento-card-icon" style="background: linear-gradient(135deg, rgba(244,114,182,0.2) 0%, rgba(244,114,182,0.1) 100%); border-color: rgba(244,114,182,0.2);">
              <Briefcase size={24} class="text-pink" />
            </div>
            <span class="text-xs font-medium text-text-muted uppercase tracking-widest">Services</span>
          </div>
          <div class="space-y-4">
            {services.map(service => (
              <div class="p-4 rounded-2xl bg-white/5 border border-white/5 hover:border-white/10 transition-all">
                <div class="flex items-center gap-3">
                  <service.icon size={18} class="text-accent flex-shrink-0" />
                  <div>
                    <h4 class="font-semibold text-sm">{service.title}</h4>
                    <p class="text-xs text-text-muted">{service.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Skills Card -->
        <div class="bento-sm bento-card animate-on-scroll stagger-4">
          <div class="bento-card-header">
            <div class="bento-card-icon">
              <Layers size={24} class="text-accent" />
            </div>
          </div>
          <h3 class="bento-card-title text-lg mb-4">Tech Stack</h3>
          <div class="flex flex-wrap gap-2">
            {skills.map(skill => (
              <span class="tag">
                <skill.icon size={14} />
                {skill.name}
              </span>
            ))}
          </div>
        </div>

        <!-- Featured Project -->
        <div class="bento-md bento-card bento-card-accent group animate-on-scroll stagger-5" style="cursor: pointer;">
          <div class="bento-card-header">
            <div class="bento-card-icon">
              <Zap size={24} class="text-accent" />
            </div>
            <ExternalLink size={18} class="text-text-muted" />
          </div>
          <div class="aspect-video rounded-2xl mb-4 flex items-center justify-center relative overflow-hidden bg-gradient-to-br from-accent/20 to-pink/20 group-hover:from-accent/30 group-hover:to-pink/30 transition-all">
            <div class="absolute inset-0 bg-gradient-to-t from-background/50 to-transparent"></div>
            <div class="relative z-10 w-20 h-20 rounded-2xl bg-accent/20 flex items-center justify-center">
              <Zap size={36} class="text-accent" />
            </div>
          </div>
          <h4 class="bento-card-title group-hover:text-accent transition-colors text-lg">
            Omni-Server Frame
          </h4>
          <p class="text-sm text-text-muted mt-2">
            AI-powered GitHub development platform
          </p>
        </div>

        <!-- Latest Post -->
        <div class="bento-sm bento-card bento-card-cyan group animate-on-scroll stagger-5" style="cursor: pointer;">
          <div class="bento-card-header">
            <div class="bento-card-icon" style="background: linear-gradient(135deg, rgba(34,211,238,0.2) 0%, rgba(34,211,238,0.1) 100%); border-color: rgba(34,211,238,0.2);">
              <FileText size={24} class="text-cyan" />
            </div>
            <ArrowRight size={18} class="text-text-muted transition-transform group-hover:translate-x-1" />
          </div>
          <h4 class="bento-card-title text-base mb-2 group-hover:text-cyan transition-colors">
            The Complete Guide to Bento Grids
          </h4>
          <p class="text-xs text-text-muted">Coming soon...</p>
        </div>

        <!-- CTA Card -->
        <div class="bento-md bento-card bento-card-accent animate-on-scroll stagger-6" style="background: linear-gradient(145deg, rgba(139,92,246,0.2) 0%, rgba(20,20,30,0.95) 100%); border-color: rgba(139,92,246,0.3);">
          <div class="text-center py-6">
            <h3 class="text-2xl font-bold mb-4">Let's Work Together</h3>
            <p class="text-text-secondary mb-8 max-w-md mx-auto" style="line-height: 1.7;">
              Have a project in mind? I'd love to hear about it. Let's create something amazing together.
            </p>
            <a href="/contact" class="btn-primary group inline-flex text-base px-8 py-4">
              <span>Start a Project</span>
              <ArrowRight size={20} class="transition-transform group-hover:translate-x-1" />
            </a>
          </div>
        </div>

        <!-- Social Connect -->
        <div class="bento-sm bento-card animate-on-scroll stagger-6">
          <div class="bento-card-header">
            <div class="bento-card-icon">
              <MessageCircle size={24} class="text-accent" />
            </div>
          </div>
          <h3 class="bento-card-title text-lg mb-4">Connect</h3>
          <div class="space-y-3">
            {socialLinks.map(link => (
              <a 
                href={link.href}
                class="flex items-center justify-between p-3 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 hover:border-white/15 transition-all group"
              >
                <span class="flex items-center gap-3">
                  <link.icon size={18} />
                  <span class="text-sm font-medium">{link.label}</span>
                </span>
                <ArrowRight size={16} class="text-text-muted opacity-0 group-hover:opacity-100 transition-opacity" />
              </a>
            ))}
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
