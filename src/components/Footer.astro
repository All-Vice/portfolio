---
import { Github, Twitter, Linkedin, Heart } from 'lucide-astro';

const socialLinks = [
  { href: 'https://github.com/All-Vice', label: 'GitHub', icon: Github },
  { href: '#', label: 'Twitter', icon: Twitter },
  { href: '#', label: 'LinkedIn', icon: Linkedin },
];

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/services', label: 'Services' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border mt-20 bg-surface/50">
  <div class="container-main py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="text-2xl font-heading font-bold text-gradient">
          All-Vice
        </a>
        <p class="mt-4 text-text-secondary max-w-md" style="line-height: 1.7;">
          Web designer & developer crafting beautiful, functional websites. 
          Specialized in modern design systems and memorable user experiences.
        </p>
        <div class="flex gap-3 mt-6">
          {socialLinks.map(link => (
            <a 
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="icon-glass hover:text-accent"
              aria-label={link.label}
            >
              <link.icon size={18} />
            </a>
          ))}
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-heading font-semibold mb-4">Navigation</h4>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a 
                href={link.href} 
                class="text-text-secondary hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading font-semibold mb-4">Get in Touch</h4>
        <ul class="space-y-3 text-text-secondary">
          <li class="flex items-center gap-2">
            <span>Available for projects</span>
          </li>
          <li>
            <a href="/contact" class="text-accent hover:text-accent-secondary transition-colors">
              Start a conversation →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-text-muted text-sm">
        © {currentYear} All-Vice. Built with Astro & Tailwind CSS.
      </p>
      <p class="text-text-muted text-sm flex items-center gap-1">
        Designed & Built with <Heart size={14} class="text-accent-tertiary" />
      </p>
    </div>
  </div>
</footer>
